    "testMatch": [
      "**/src/**/*.test.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corbym/vtir.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/corbym/vtir/issues"
  },
  "homepage": "https://github.com/corbym/vtir#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  }
}
